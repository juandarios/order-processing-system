{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrderIntakeDb": "Host=localhost;Port=5432;Database=order-intake-db;Username=postgres;Password=${DB_PASSWORD}"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "GroupId": "order-intake-group",
    "OrderPlacedTopic": "order-placed",
    "DlqTopic": "order-placed-dlq",
    "ValidationErrorTopic": "order-validation-errors"
  },
  "Services": {
    "StockService": "http://localhost:5010/",
    "Orchestrator": "http://localhost:5030/"
  },
  "ResiliencePolicy": {
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 2,
    "CircuitBreakerFailureRatio": 1.0,
    "CircuitBreakerMinimumThroughput": 5,
    "CircuitBreakerSamplingDurationSeconds": 30,
    "CircuitBreakerBreakDurationSeconds": 30
  }
}

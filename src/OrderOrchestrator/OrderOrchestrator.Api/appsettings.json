{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrchestratorDb": "Host=localhost;Port=5432;Database=orchestrator-db;Username=postgres;Password=${DB_PASSWORD}"
  },
  "Services": {
    "PaymentService": "http://localhost:5020/"
  },
  "ResiliencePolicy": {
    "MaxRetryAttempts": 3,
    "RetryDelaySeconds": 2,
    "CircuitBreakerFailureRatio": 1.0,
    "CircuitBreakerMinimumThroughput": 5,
    "CircuitBreakerSamplingDurationSeconds": 30,
    "CircuitBreakerBreakDurationSeconds": 30
  }
}
